{
  "schemaVersion": 1,
  "id": "simplesync",
  "version": "${version}",
  "name": "SimpleSync",
  "description": "Sync your singleplayer worlds across multiple computers via cloud storage. Play anywhere, always up to date.",
  "authors": [
    "SimpleSync Contributors"
  ],
  "contact": {
    "sources": "https://github.com/simplesync/simplesync"
  },
  "license": "MIT",
  "icon": "assets/simplesync/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.simplesync.SimpleSync"
    ],
    "client": [
      "dev.simplesync.SimpleSyncClient"
    ],
    "modmenu": [
      "dev.simplesync.compat.ModMenuIntegration"
    ]
  },
  "mixins": [
    {
      "config": "simplesync.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.19.0",
    "minecraft": "~26.2",
    "java": ">=25",
    "fabric-api": ">=0.154.0"
  }
}
